# Set by expo-router. This enables Fabric-only features from react-native-screens
ENV['RNS_GAMMA_ENABLED'] ||= '1'
require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

def append_unique_build_setting_values(existing, values)
  current_values =
    case existing
    when Array
      existing.dup
    when String
      existing.split(/\s+/)
    when nil
      []
    else
      Array(existing)
    end

  (current_values + values).uniq
end

def configure_fmt_build_settings!(build_configuration)
  build_configuration.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
  build_configuration.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] =
    append_unique_build_setting_values(
      build_configuration.build_settings['GCC_PREPROCESSOR_DEFINITIONS'],
      ['$(inherited)', 'FMT_USE_CONSTEVAL=0'],
    )
  build_configuration.build_settings['OTHER_CPLUSPLUSFLAGS'] =
    append_unique_build_setting_values(
      build_configuration.build_settings['OTHER_CPLUSPLUSFLAGS'],
      ['$(inherited)', '-DFMT_USE_CONSTEVAL=0'],
    )
end

# fmt 11.0.2 enables compile-time format-string checking via `consteval`
# (FMT_CONSTEVAL) whenever the compiler reports __cpp_consteval. Apple clang 21
# (Xcode 26+) tightened constant-evaluation and rejects fmt's FMT_STRING
# machinery ("call to consteval function ... is not a constant expression"),
# breaking the build of fmt/src/format.cc. fmt's base.h redefines
# FMT_USE_CONSTEVAL UNCONDITIONALLY (no #ifndef guard), so a -DFMT_USE_CONSTEVAL=0
# build flag is ignored, and the c++17 escape hatch does not apply because RN
# compiles all pods as c++20. We therefore patch the vendored header to force
# FMT_USE_CONSTEVAL to 0 (falls back to runtime format-string checking). Runs on
# every `pod install`; idempotent.
def patch_fmt_consteval!(installer)
  base_h = File.join(installer.sandbox.root.to_s, 'fmt', 'include', 'fmt', 'base.h')
  return unless File.exist?(base_h)

  contents = File.read(base_h)
  return if contents.include?('Columbo: force-disable consteval')

  marker = "#if FMT_USE_CONSTEVAL\n#  define FMT_CONSTEVAL consteval"
  override = "// Columbo: force-disable consteval (broken under Apple clang 21 / Xcode 26)\n" \
             "#undef FMT_USE_CONSTEVAL\n" \
             "#define FMT_USE_CONSTEVAL 0\n" \
             "#if FMT_USE_CONSTEVAL\n#  define FMT_CONSTEVAL consteval"

  unless contents.include?(marker)
    Pod::UI.warn '[fmt] Could not find consteval marker to patch; build may fail under Apple clang 21.'
    return
  end

  begin
    File.chmod(0o644, base_h)
    File.write(base_h, contents.sub(marker, override))
    Pod::UI.message '[fmt] Patched base.h to disable consteval (Apple clang 21 workaround).'
  rescue => e
    Pod::UI.warn "[fmt] Failed to patch base.h (#{e.message}); build may fail under Apple clang 21."
  end
end

def ccache_enabled?(podfile_properties)
  # Environment variable takes precedence
  return ENV['USE_CCACHE'] == '1' if ENV['USE_CCACHE']

  # Fall back to Podfile properties
  podfile_properties['apple.ccacheEnabled'] == 'true'
end

ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] ||= podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']
ENV['RCT_USE_RN_DEP'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true'
ENV['RCT_USE_PREBUILT_RNCORE'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true'
ENV['RCT_HERMES_V1_ENABLED'] ||= '1' if podfile_properties['expo.useHermesV1'] == 'true'
platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'

prepare_react_native_project!

target 'Columbo' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(\'expo/bin/autolinking\')',
      'expo-modules-autolinking',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => ccache_enabled?(podfile_properties),
    )

    patch_fmt_consteval!(installer)

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |build_configuration|
        build_configuration.build_settings['CLANG_ENABLE_EXPLICIT_MODULES'] = 'NO'
        build_configuration.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
        build_configuration.build_settings['SWIFT_ENABLE_EXPLICIT_MODULES'] = 'NO'

        next unless target.name == 'fmt'

        configure_fmt_build_settings!(build_configuration)
      end
    end

    installer.aggregate_targets.map(&:user_project).uniq.each do |user_project|
      user_project.native_targets.each do |target|
        target.build_configurations.each do |build_configuration|
          build_configuration.build_settings['CLANG_ENABLE_EXPLICIT_MODULES'] = 'NO'
          build_configuration.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
          build_configuration.build_settings['SWIFT_ENABLE_EXPLICIT_MODULES'] = 'NO'
          build_configuration.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] =
            append_unique_build_setting_values(
              build_configuration.build_settings['GCC_PREPROCESSOR_DEFINITIONS'],
              ['$(inherited)', 'FMT_USE_CONSTEVAL=0'],
            )
        end

        next unless target.name == 'Columbo'

        phase_name = '[Hermes] Generate dSYM'
        phase = target.shell_script_build_phases.find { |build_phase| build_phase.name == phase_name }
        phase ||= target.new_shell_script_build_phase(phase_name)
        phase.shell_path = '/bin/sh'
        phase.input_paths = ['${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}/hermesvm.framework/hermesvm']
        phase.output_paths = ['${DWARF_DSYM_FOLDER_PATH}/hermesvm.framework.dSYM']
        phase.shell_script = <<~'SCRIPT'
          HERMES_BINARY_PATH="${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}/hermesvm.framework/hermesvm"
          HERMES_DSYM_PATH="${DWARF_DSYM_FOLDER_PATH}/hermesvm.framework.dSYM"

          if [ ! -f "$HERMES_BINARY_PATH" ]; then
            echo "warning: Hermes framework binary not found at $HERMES_BINARY_PATH"
            exit 0
          fi

          rm -rf "$HERMES_DSYM_PATH"
          if ! xcrun dsymutil "$HERMES_BINARY_PATH" -o "$HERMES_DSYM_PATH"; then
            echo "warning: Failed to generate Hermes dSYM from $HERMES_BINARY_PATH"
            exit 0
          fi

          if [ -n "${ARCHIVE_DSYMS_PATH:-}" ]; then
            mkdir -p "$ARCHIVE_DSYMS_PATH"
            rsync -a --delete "$HERMES_DSYM_PATH" "$ARCHIVE_DSYMS_PATH"
          fi
        SCRIPT
      end

      user_project.save
    end
  end
end
